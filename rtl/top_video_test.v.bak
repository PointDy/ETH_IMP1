module top_video_test (
    input  wire        sys_clk_50m,  // 开发板外部 50MHz 晶振
    input  wire        sys_rst_n,    // 开发板外部复位按键 (低电平有效)

    // === OV5640 摄像头物理接口 ===
    output wire        cam_scl,
    inout  wire        cam_sda,
    input  wire        cam_vsync,
    input  wire        cam_href,
    input  wire        cam_pclk,
    input  wire [7:0]  cam_data,
    output wire        cam_reset,    // 摄像头硬件复位引脚
    output wire        cam_pwdn,     // 摄像头休眠控制引脚

    // === SDRAM (W9825G6KH) 物理接口 ===
    output wire        sdram_clk,
    output wire        sdram_cke,
    output wire        sdram_cs_n,
    output wire        sdram_ras_n,
    output wire        sdram_cas_n,
    output wire        sdram_we_n,
    output wire [1:0]  sdram_ba,
    output wire [12:0] sdram_addr,
    inout  wire [15:0] sdram_dq,
    output wire [1:0]  sdram_dqm,

    // === LAN8720A 百兆网口物理接口 (RMII) ===
    input  wire        eth_rx_clk,     // PHY 提供的 50MHz 接收时钟
    input  wire        eth_rxdv,       
    input  wire [1:0]  eth_rx_data,    
    input  wire        eth_tx_clk,     // PHY 提供的 50MHz 发送时钟
    output wire        eth_tx_en,      
    output wire [1:0]  eth_tx_data,    
    output wire        eth_rst_n       // PHY 芯片复位
);

    // =========================================================
    // 1. 系统时钟与全局复位管理
    // =========================================================
    wire clk_100m;       // 100MHz 内部工作时钟 (0相位)
    wire clk_100m_shift; // 100MHz SDRAM 外部时钟 (-75度相位)
    wire pll_locked;
    
    // 只有当复位按键没按下，且 PLL 锁定输出稳定时，系统才开始工作
    wire rst_n = sys_rst_n & pll_locked; 
    
    // 直接将偏移时钟输出给 SDRAM 物理引脚
    assign sdram_clk = clk_100m_shift; 

    // 例化生成的 PLL
    pll_inst u_pll (
        .inclk0 (sys_clk_50m),
        .c0     (clk_100m),
        .c1     (clk_100m_shift),
        .locked (pll_locked)
    );

    // =========================================================
    // 2. 摄像头采集端 (OV5640)
    // =========================================================
    wire        cam_cfg_done;
    wire [15:0] cam_pixel_data;
    wire        cam_wr_en; 
    
    // 顶层硬布线：摄像头电源与复位控制
    assign cam_pwdn  = 1'b0;    // 正常工作模式 (低电平)
    assign cam_reset = rst_n;   // 硬件复位引脚跟随系统复位

    // 例化摄像头底层驱动模块
    ov5640_top u_ov5640_top (
        .sys_clk        (sys_clk_50m),     // 输入 50MHz 时钟以匹配 I2C 模块参数
        .sys_rst_n      (rst_n),
        .sys_init_done  (cam_cfg_done),    // 配置完成后才允许数据输出
        
        .ov5640_pclk    (cam_pclk),
        .ov5640_href    (cam_href),
        .ov5640_vsync   (cam_vsync),
        .ov5640_data    (cam_data),
        
        .cfg_done       (cam_cfg_done),
        .sccb_scl       (cam_scl),
        .sccb_sda       (cam_sda),
        
        .ov5640_wr_en   (cam_wr_en),
        .ov5640_data_out(cam_pixel_data)
    );

    // 实例化摄像头的异步跨时钟域 FIFO (cam_fifo)
    wire        cam_fifo_empty;
    wire [15:0] cam_fifo_rd_data;
    wire        cam_fifo_rd_en;

    cam_fifo u_cam_fifo (
        .wrclk   (cam_pclk),
        .wrreq   (cam_wr_en),
        .data    (cam_pixel_data),
        
        .rdclk   (clk_100m),
        .rdreq   (cam_fifo_rd_en),
        .q       (cam_fifo_rd_data),
        .rdempty (cam_fifo_empty),
        .wrfull  () // 悬空
    );

    // =========================================================
    // 3. 核心桥接器与 Qsys 仲裁系统 (4通道超级总线)
    // =========================================================
    
    // --- 通道 1 连线：摄像头写入 ---
    wire [24:0] port1_address;
    wire        port1_write;
    wire [15:0] port1_writedata;
    wire        port1_waitrequest;

    avalon_write_bridge #(
        .ADDR_WIDTH (25), .DATA_WIDTH (16)
    ) u_cam_wr_bridge (
        .clk             (clk_100m),
        .rst_n           (rst_n),
        .fifo_empty      (cam_fifo_empty),
        .fifo_rd_data    (cam_fifo_rd_data),
        .fifo_rd_en      (cam_fifo_rd_en),
        .avm_address     (port1_address),
        .avm_write       (port1_write),
        .avm_writedata   (port1_writedata),
        .avm_waitrequest (port1_waitrequest),
        .base_addr       (25'h0000000),      
        .max_addr        (25'd960000) // 800 * 600 * 2 (字节)
    );

    // --- 通道 4 连线：以太网读取 ---
    wire [24:0] port4_address;
    wire        port4_read;
    wire [15:0] port4_readdata;
    wire        port4_readdatavalid;
    wire        port4_waitrequest;
    
    wire [10:0] eth_fifo_wrusedw; // 匹配 eth_fifo 写侧 11-bit
    wire        eth_fifo_wr_en;
    wire [15:0] eth_fifo_wr_data;

    avalon_read_bridge #(
        .ADDR_WIDTH (25), .DATA_WIDTH (16), .FIFO_THRESHOLD(512)
    ) u_eth_rd_bridge (
        .clk             (clk_100m),
        .rst_n           (rst_n),
        // 用 5 个 0 补齐高位，凑成 16-bit 送入模块
        .fifo_usedw      ({5'd0, eth_fifo_wrusedw}), 
        .fifo_wr_en      (eth_fifo_wr_en),
        .fifo_wr_data    (eth_fifo_wr_data),
        .avm_address     (port4_address),
        .avm_read        (port4_read),
        .avm_readdata    (port4_readdata),
        .avm_readdatavalid(port4_readdatavalid),
        .avm_waitrequest (port4_waitrequest),
        .base_addr       (25'h0000000),      
        .max_addr        (25'd960000)
    );

    // --- 例化 Qsys 4端口 SDRAM 系统 ---
    sdram_4port_sys u_sdram_sys (
        .clk_clk                      (clk_100m),
        .reset_reset_n                (rst_n),
        
        .sdram_wire_addr              (sdram_addr),
        .sdram_wire_ba                (sdram_ba),
        .sdram_wire_cas_n             (sdram_cas_n),
        .sdram_wire_cke               (sdram_cke),
        .sdram_wire_cs_n              (sdram_cs_n),
        .sdram_wire_dq                (sdram_dq),
        .sdram_wire_dqm               (sdram_dqm),
        .sdram_wire_ras_n             (sdram_ras_n),
        .sdram_wire_we_n              (sdram_we_n),

        // 端口1：摄像头写
        .port1_cam_wr_address         (port1_address),
        .port1_cam_wr_write           (port1_write),
        .port1_cam_wr_writedata       (port1_writedata),
        .port1_cam_wr_waitrequest     (port1_waitrequest),
        
        // 端口2和3：预留给你的差分算法逻辑 (后续加入)
        // .port2_diff_rd_...         (),
        // .port3_diff_wr_...         (),

        // 端口4：网卡读
        .port4_eth_rd_address         (port4_address),
        .port4_eth_rd_read            (port4_read),
        .port4_eth_rd_readdata        (port4_readdata),
        .port4_eth_rd_readdatavalid   (port4_readdatavalid),
        .port4_eth_rd_waitrequest     (port4_waitrequest)
    );

    // =========================================================
    // 4. 以太网传输端 (LAN8720A)
    // =========================================================
    
    wire [9:0]  eth_fifo_rdusedw; // 匹配 eth_fifo 读侧 10-bit
    wire        eth_fifo_rd_en;
    wire [31:0] eth_fifo_rd_data;
    
    // 例化生成的非对称 eth_fifo
    eth_fifo u_eth_fifo (
        .data    (eth_fifo_wr_data),
        .wrclk   (clk_100m),          
        .wrreq   (eth_fifo_wr_en),
        .wrusedw (eth_fifo_wrusedw),  // 写余量 11-bit
        .wrfull  (),                  
        
        .rdclk   (eth_tx_clk),        // 网卡发送时钟 50MHz
        .rdreq   (eth_fifo_rd_en),
        .q       (eth_fifo_rd_data),
        .rdusedw (eth_fifo_rdusedw),  // 读余量 10-bit
        .rdempty ()                   
    );

    // --- 自动触发网络发包状态机 ---
    // 逻辑：如果网卡空闲，且 FIFO 里的 32-bit 数据攒够了 200 个 (刚好 800 字节)，就自动开火！
    reg  eth_send_en;
    wire eth_send_end;
    reg  eth_sending_state;
    
    always @(posedge eth_tx_clk or negedge rst_n) begin
        if (!rst_n) begin
            eth_send_en       <= 1'b0;
            eth_sending_state <= 1'b0;
        end else begin
            if (eth_send_end) begin
                eth_sending_state <= 1'b0; // 一包 800 字节发完，释放状态
            end
            
            // 当数据量 >= 200 时触发单次发送脉冲
            if (!eth_sending_state && eth_fifo_rdusedw >= 10'd200) begin
                eth_send_en       <= 1'b1; 
                eth_sending_state <= 1'b1;
            end else begin
                eth_send_en       <= 1'b0;
            end
        end
    end

    // --- 例化透明拦截器版的 UDP 发送模块 ---
    eth_udp_rmii u_eth_udp (
        .eth_rmii_clk    (eth_rx_clk),
        .eth_mii_clk     (eth_tx_clk), 
        .sys_rst_n       (rst_n),
        
        .rx_dv           (eth_rxdv),
        .rx_data         (eth_rx_data),
        
        .send_en         (eth_send_en),
        .send_data       (eth_fifo_rd_data),
        .send_data_num   (16'd800),     // 每包发送 800 字节的图像净载荷
        
        .send_end        (eth_send_end),
        .read_data_req   (eth_fifo_rd_en), 
        
        // 预留的波门坐标接收口
        .rec_end         (),
        .rec_en          (),
        .rec_data        (),
        .rec_data_num    (),
        
        .eth_tx_dv       (eth_tx_en),
        .eth_tx_data     (eth_tx_data),
        .eth_rst_n       (eth_rst_n)
    );

endmodule