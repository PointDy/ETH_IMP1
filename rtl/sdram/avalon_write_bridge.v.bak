module avalon_write_bridge #(
    parameter ADDR_WIDTH = 25,  // 对应 32MB 的地址位宽
    parameter DATA_WIDTH = 16   // 16-bit RGB565 数据
)(
    input  wire                   clk,
    input  wire                   rst_n,

    // === 用户 FIFO 接口 (读 FIFO 侧) ===
    input  wire                   fifo_empty,    // FIFO 空标志
    input  wire [DATA_WIDTH-1:0]  fifo_rd_data,  // FIFO 吐出的数据 (必须是 FWFT 模式)
    output reg                    fifo_rd_en,    // 桥接器发给 FIFO 的读请求

    // === Avalon-MM Master 接口 (接 Qsys) ===
    output reg  [ADDR_WIDTH-1:0]  avm_address,
    output reg                    avm_write,
    output reg  [DATA_WIDTH-1:0]  avm_writedata,
    input  wire                   avm_waitrequest,

    // === 控制接口 ===
    input  wire [ADDR_WIDTH-1:0]  base_addr,     // 画面在 SDRAM 中的起始地址 (如 0x0000000)
    input  wire [ADDR_WIDTH-1:0]  max_addr       // 画面在 SDRAM 中的结束地址 (800x600x2 = 960000)
);

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            avm_write     <= 1'b0;
            avm_writedata <= 16'd0;
            avm_address   <= base_addr;
            fifo_rd_en    <= 1'b0;
        end else begin
            // 默认拉低 FIFO 读使能，产生单时钟脉冲
            fifo_rd_en <= 1'b0;

            if (avm_write) begin
                // 状态：正在请求写入 Avalon 总线
                if (!avm_waitrequest) begin
                    // Qsys 接收了写入请求
                    avm_write <= 1'b0;
                    
                    // 地址递增与回环判断 (Avalon 默认按字节寻址，16位数据需 +2)
                    if (avm_address >= max_addr - 2) 
                        avm_address <= base_addr;
                    else 
                        avm_address <= avm_address + 2;
                end
            end 
            else if (!fifo_empty) begin
                // 状态：空闲且 FIFO 中有新数据
                avm_write     <= 1'b1;
                avm_writedata <= fifo_rd_data;
                fifo_rd_en    <= 1'b1; // 通知 FIFO 弹出下一个数据准备好
            end
        end
    end

endmodule