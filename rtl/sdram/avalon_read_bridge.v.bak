module avalon_read_bridge #(
    parameter ADDR_WIDTH = 25,
    parameter DATA_WIDTH = 16,
    parameter FIFO_THRESHOLD = 512  // 水位线：当 FIFO 数据量低于此值时发起连续读取
)(
    input  wire                   clk,
    input  wire                   rst_n,

    // === 用户 FIFO 接口 (写 FIFO 侧) ===
    input  wire [15:0]            fifo_usedw,    // 下游 FIFO 当前已缓存的数据个数
    output reg                    fifo_wr_en,    // 桥接器输出给 FIFO 的写使能
    output reg  [DATA_WIDTH-1:0]  fifo_wr_data,  // 桥接器输出给 FIFO 的数据

    // === Avalon-MM Master 接口 (接 Qsys) ===
    output reg  [ADDR_WIDTH-1:0]  avm_address,
    output reg                    avm_read,
    input  wire [DATA_WIDTH-1:0]  avm_readdata,
    input  wire                   avm_readdatavalid,
    input  wire                   avm_waitrequest,

    // === 控制接口 ===
    input  wire [ADDR_WIDTH-1:0]  base_addr,     // 画面在 SDRAM 中的起始地址
    input  wire [ADDR_WIDTH-1:0]  max_addr       // 画面在 SDRAM 中的结束地址
);

    reg [15:0] pending_reads; // 追踪已发出但还没收到数据的请求数

    // 握手成功信号
    wire read_accepted = avm_read && !avm_waitrequest;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            avm_read      <= 1'b0;
            avm_address   <= base_addr;
            pending_reads <= 16'd0;
            fifo_wr_en    <= 1'b0;
            fifo_wr_data  <= 16'd0;
        end else begin
            // --------------------------------------------------
            // 1. 发送读请求 (Command Phase)
            // --------------------------------------------------
            if (read_accepted) begin
                avm_read <= 1'b0; // 默认拉低，除非下一个周期继续符合条件
                
                // 地址递增与回环 (16位数据需 +2)
                if (avm_address >= max_addr - 2)
                    avm_address <= base_addr;
                else
                    avm_address <= avm_address + 2;
            end 
            else if (!avm_read) begin
                // 如果下游 FIFO 加上在途的数据总量低于阈值，则发起新的读请求
                if ((fifo_usedw + pending_reads) < FIFO_THRESHOLD) begin
                    avm_read <= 1'b1;
                end
            end

            // --------------------------------------------------
            // 2. 接收数据并写入 FIFO (Response Phase)
            // --------------------------------------------------
            // 只要 Qsys 吐出 valid 信号，就无脑存入下游 FIFO
            fifo_wr_en   <= avm_readdatavalid;
            fifo_wr_data <= avm_readdata;

            // --------------------------------------------------
            // 3. 维护在途请求计数器 (Pending Reads)
            // --------------------------------------------------
            if (read_accepted && !avm_readdatavalid)
                pending_reads <= pending_reads + 1'b1;
            else if (!read_accepted && avm_readdatavalid)
                pending_reads <= pending_reads - 1'b1;
        end
    end

endmodule